<MudDialog>
    <DialogContent>
        <MudText>Are you sure you want to delete your history? This cannot be undone.</MudText>
    </DialogContent>
    <DialogActions>
        <SirenButton Variant="Variant.Text" OnClick="Cancel">Cancel</SirenButton>
        <SirenButton Color="Color.Error" Variant="Variant.Outlined" OnClick="Submit">Delete</SirenButton>
    </DialogActions>
</MudDialog>
@code {
    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; }

    private void Submit() => MudDialog.Close(DialogResult.Ok(true));

    private void Cancel() => MudDialog.Cancel();
}