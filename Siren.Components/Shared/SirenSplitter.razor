@inherits SirenBaseComponent

<MudSplitPanel Horizontal="@Horizontal"
               MinPanelSize="50"
               PanelGap="4"
               Transparent="true"
               Class="@($"{Class} mud-height-full")"
               Style="@Style">
    <FirstPanel>
        @Panel1
    </FirstPanel>
    <SecondPanel>
        @Panel2
    </SecondPanel>
</MudSplitPanel>

@code {
    [Parameter]
    public RenderFragment Panel1 { get; set; } = default!;

    [Parameter]
    public RenderFragment Panel2 { get; set; } = default!;

    [Parameter]
    public bool Horizontal { get; set; }
}
